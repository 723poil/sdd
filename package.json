{
  "name": "sdd",
  "productName": "SDD",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/main.js",
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "scripts": {
    "generate:icons": "node --experimental-strip-types ./scripts/generate-icon-assets.ts",
    "dev": "node --experimental-strip-types ./scripts/run-dev.ts",
    "dev:raw": "electron-vite dev",
    "prepare:dev:mac-app": "node --experimental-strip-types ./scripts/prepare-dev-mac-app.ts",
    "build": "tsc --noEmit && electron-vite build",
    "bundle": "electron-vite build",
    "dist:mac": "npm run bundle && electron-builder --mac dir",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --import ./tests/register-path-aliases.ts --test tests/**/*.test.ts",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "build": {
    "appId": "com.sdd.desktop",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "electronDist": "node_modules/electron/dist",
    "extraResources": [
      {
        "from": "build/icon/sdd-icon.png",
        "to": "icon/sdd-icon.png"
      }
    ],
    "files": [
      "out/main/**/*",
      "out/preload/**/*",
      "out/renderer/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon/sdd.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dir"
      ]
    }
  },
  "dependencies": {
    "mermaid": "^11.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1"
  }
}
